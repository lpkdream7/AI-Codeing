# Public application URL. Replace after ICP filing and DNS are ready.
APP_URL=https://todo.example.com

# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-with-at-least-32-random-bytes

# MySQL container and application connection.
MYSQL_DATABASE=today_list
MYSQL_USER=today_list_app
MYSQL_PASSWORD=replace-with-a-strong-application-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-strong-root-password
DATABASE_URL=mysql://today_list_app:replace-with-a-strong-application-password@mysql:3306/today_list

# SMTP is required for email verification and password reset.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM="Today List <no-reply@example.com>"
