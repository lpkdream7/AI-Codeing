# Before ICP filing, keep HTTP-only IP access (prefer an SSH tunnel).
APP_DOMAIN=:80
COOKIE_SECURE=false
REGISTRATION_ENABLED=true

# Public host ports. Do not expose MySQL port 3306.
HTTP_PORT=80
HTTPS_PORT=443
NPM_REGISTRY=https://registry.npmmirror.com

# After ICP filing and DNS setup, use for example:
# APP_DOMAIN=todo.example.com
# COOKIE_SECURE=true

# Database passwords are generated into deploy/secrets by start.sh.
